local visorAtivo = false
local visorBoards = {}

local function criarVisor(plr, sound)
    if visorBoards[plr] then visorBoards[plr]:Destroy() end
    local ok, info = pcall(function()
        return MarketplaceService:GetProductInfo(tonumber(sound.SoundId:gsub("%D","")))
    end)
    if not ok or not info then return end
    local root = plr.Character and plr.Character:FindFirstChild("HumanoidRootPart")
    if not root then return end
    local bb = Instance.new("BillboardGui")
    bb.Adornee = root
    bb.Size = UDim2.new(0,220,0,50)
    bb.StudsOffset = Vector3.new(0,4,0)
    bb.AlwaysOnTop = true
    bb.Parent = root
    local tl = Instance.new("TextLabel",bb)
    tl.Size = UDim2.new(1,0,1,0)
    tl.BackgroundTransparency = 0.3
    tl.BackgroundColor3 = Color3.fromRGB(10,10,10)
    tl.TextColor3 = Color3.fromRGB(0,255,200)
    tl.Font = Enum.Font.GothamBold
    tl.TextScaled = true
    tl.Text = "🎵 "..info.Name
    visorBoards[plr] = bb
    sound.AncestryChanged:Connect(function(_,p)
        if not p and bb then bb:Destroy(); visorBoards[plr]=nil end
    end)
end

