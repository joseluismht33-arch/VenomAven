		local response = game:HttpGet(url)
		return HttpService:JSONDecode(response)
	end)

	if success then
		print("✅ Dados carregados da API:", url, "Total:", #result)
		return result
	else
		warn("⚠️ Erro ao buscar dados da API:", url, result)
		return {}
	end
