Tab9:AddSection({"Kill Bus"})
Tab9:AddButton({Name="🚌 Kill Bus",Callback=function()
    if not selectedPlayerName then Notify("Erro","Selecione um jogador!",3) return end
    local character=localPlayer.Character
    local hrp=character and character:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    local originalPos=hrp.CFrame
    local Vehicles=workspace:FindFirstChild("Vehicles")
    if not Vehicles then return end
    local bus=Vehicles:FindFirstChild(localPlayer.Name.."Car")
    if not bus then
        hrp.CFrame=CFrame.new(1118.81,75.998,-1138.61)
        task.wait(0.5)
        ReplicatedStorage.RE:FindFirstChild("1Ca1r"):FireServer("PickingCar","SchoolBus")
        task.wait(1)
        bus=Vehicles:FindFirstChild(localPlayer.Name.."Car")
    end
    if bus then
        local hum=character:FindFirstChildOfClass("Humanoid")
        local seat=bus:FindFirstChild("Body") and bus.Body:FindFirstChild("VehicleSeat")
        if seat and hum and not hum.Sit then
            repeat hrp.CFrame=seat.CFrame*CFrame.new(0,2,0);task.wait() until hum.Sit or not bus.Parent
        end
        task.spawn(function()
            while true do
                local tp=Players:FindFirstChild(selectedPlayerName)
                if tp and tp.Character and tp.Character:FindFirstChild("HumanoidRootPart") then
                    local tHum=tp.Character:FindFirstChildOfClass("Humanoid")
                    if tHum and tHum.Sit then
                        if bus then bus:SetPrimaryPartCFrame(CFrame.new(9999,-450,9999)) end
                        task.wait(0.5);hrp.CFrame=originalPos;break
                    else
                        local tRoot=tp.Character.HumanoidRootPart
                        local time=tick()*35
                        bus:SetPrimaryPartCFrame(tRoot.CFrame*CFrame.new(math.sin(time)*4,0,math.cos(time)*20))
                    end
                end
                RunService.RenderStepped:Wait()
            end
        end)
        Notify("Kill Bus","Bus ativado! 🚌",3)
    end
end})

